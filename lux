#!/usr/bin/env bash
set -euo pipefail

usage() {
    echo "Usage: lux <command>"
    echo ""
    echo "Commands:"
    echo "  commit    Pull with rebase, compile, test, and push"
    echo "  docs    start the docs instance"
    exit 1
}

cmd_commit() {
    echo "Pulling with rebase..."
    git pull --rebase --autostash

    echo "Running tests..."
    TEST_MODE=VERTX mvn test

    echo "Done."
}

docs(){
  echo "starting docs instance"
  (cd docs && npm run build && npm run dev)
}

if [[ $# -lt 1 ]]; then
    usage
fi

case "$1" in
    commit) cmd_commit ;;
    docs) docs ;;
    *) echo "Unknown command: $1"; usage ;;
esac
