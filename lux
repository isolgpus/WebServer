#!/usr/bin/env bash
set -euo pipefail

usage() {
    echo "Usage: lux <command>"
    echo ""
    echo "Commands:"
    echo "  commit    Pull with rebase, compile, test"
    echo "  test      compile, test"
    echo "  deploy    Run tests, tag the revision, deploy to Maven Central"
    echo "  docs      start the docs instance"
    exit 1
}

cmd_commit() {
    echo "Pulling with rebase..."
    git pull --rebase --autostash

    echo "Running tests..."
    TEST_MODE=VERTX mvn test

    echo "Done."
}


cmd_test() {
    echo "Running tests..."
    TEST_MODE=VERTX mvn test

    echo "Done."
}

cmd_deploy() {
    echo "Running tests..."
    TEST_MODE=VERTX mvn test

    VERSION=$(mvn help:evaluate -Dexpression=project.version -q -DforceStdout)
    TAG="v${VERSION}"

    if git rev-parse -q --verify "refs/tags/${TAG}" >/dev/null; then
        echo "Tag ${TAG} already exists; aborting." >&2
        exit 1
    fi

    echo "Tagging ${TAG}..."
    git tag -a "${TAG}" -m "Release ${VERSION}"

    echo "Deploying to Maven Central..."
    mvn deploy

    echo "Done. Push the tag with: git push origin ${TAG}"
}



docs(){
  export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"

  if [[ ! -s "$NVM_DIR/nvm.sh" ]]; then
    echo "nvm not found, installing..."
    curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash
  fi

  # shellcheck disable=SC1091
  . "$NVM_DIR/nvm.sh"

  if ! nvm ls default >/dev/null 2>&1; then
    echo "installing Node LTS via nvm..."
    nvm install --lts
    nvm alias default 'lts/*'
  fi

  nvm use default

  echo "starting docs instance"
  (
    cd docs
    if [[ ! -d node_modules/astro ]]; then
      echo "installing docs dependencies..."
      npm install
    fi
    npm run dev
  )
}

if [[ $# -lt 1 ]]; then
    usage
fi

case "$1" in
    commit) cmd_commit ;;
    test) cmd_test ;;
    deploy) cmd_deploy ;;
    docs) docs ;;
    *) echo "Unknown command: $1"; usage ;;
esac
